
/* Pin Definitions */
#include "pins.h"

/* Define motor speeds */
#include "defines.h"

/* Melody Definitions */
#include "melody.h"

/* QTR Sensor Definitions */
#include "qtr.h"

/* IR Sensor Definitions */
#include "ir.h"

QTRSensors qtr; // Create QTR object
int *QTRValues;

IRSensors ir; // Create IR sensor object
int *IRValues;

/* Function to set motor speeds */
void setMotorSpeed(int leftSpeed, int rightSpeed)
{
  analogWrite(PWMA, leftSpeed);
  analogWrite(PWMB, rightSpeed);

  // Set motor direction
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);
  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);
}
void forwardLR(int speed)
{
  setMotorSpeed(speed, speed);
}
void turnL(int speed)
{
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);

  // Set motor direction
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);

  digitalWrite(BIN1, LOW);
  digitalWrite(BIN2, HIGH);
}
void turnR(int speed)
{
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);

  // Set motor direction
  digitalWrite(AIN1, LOW);
  digitalWrite(AIN2, HIGH);

  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);
}

/* Setup and loop */
void setup()
{

  // Initialize pins
  setupPins();

  qtr.setup();
  ir.setup();

  Serial.begin(115200);
  if (Serial)
  {
    Serial.println("Serial is ready");
  }

  // Buzzer for sound alerts
  playMelody();
}

void loop()
{

  // read values
  qtr.read();
  qtr.printAllValues();

  ir.read();
  ir.printAllValues();
  IRValues = ir.getAllValues();

  // Determine opponent position (0=none, 1=back, 2=left, 3=center, 4=right)
  int opponentState = 0;
  if (IRValues[0] == 1)
    opponentState = 1; // LEFT
  else if (IRValues[1] == 1)
    opponentState = 2; // CENTER
  else if (IRValues[2] == 1)
    opponentState = 3; // RIGHT

  // React based on opponent position
  switch (opponentState)
  {
  case 0:
  { // No opponent - search pattern

    Serial.println("Searching");
    break;
  }

  case 1:
  {
    // Opponent at left - more precise turning
    // More gradual turn with slightly reduced differential

    Serial.println("Attacking left");

    turnL(ATTACK_SPEED);

    break;
  }

  case 2:
  { // Opponent at center - more precise directional control

    Serial.println("Attacking center");

    if (IRValues[0] && !IRValues[1])
    {
      // Opponent slightly left of center - gentler turn
      setMotorSpeed(ATTACK_SPEED, ATTACK_SPEED - TURN_SPEED_AGGRESSIVE);
    }
    else if (!IRValues[1] && IRValues[2])
    {
      // Opponent slightly right of center - gentler turn
      setMotorSpeed(ATTACK_SPEED - TURN_SPEED_AGGRESSIVE, ATTACK_SPEED);
    }
    else
    {
      // Direct center attack with balanced speed
      setMotorSpeed(ATTACK_SPEED, ATTACK_SPEED);
    }

    break;
  }

  case 3:
  {
    // Opponent at right - more precise turning
    // More gradual turn with slightly reduced differential

    Serial.println("Attacking right");

    turnR(ATTACK_SPEED);

    break;
  }
  }

  delay(10); // Small delay to prevent overwhelming the loop
}
